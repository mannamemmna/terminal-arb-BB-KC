generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Config {
  id   String @id @default("main")
  json String
}

model Signal {
  id         Int      @id @default(autoincrement())
  symbol     String
  message    String
  verdict    String
  spreadPct  Float
  fundingDiff Float
  createdAt  DateTime @default(now())
  @@index([symbol, createdAt])
}

model Trade {
  id          Int       @id @default(autoincrement())
  symbol      String
  sideBybit   String
  sideKucoin  String
  entrySpread Float
  exitSpread  Float?
  pnl         Float?
  status      String    @default("OPEN")
  mode        String    @default("paper")
  createdAt   DateTime  @default(now())
  closedAt    DateTime?
  @@index([status, createdAt])
  @@index([mode])
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  bybit     String
  kucoin    String
  uptime    Int
  createdAt DateTime @default(now())
  @@index([createdAt])
}

model Position {
  id             String    @id @default(uuid())
  symbol         String
  mode           String
  legAExchange   String    @default("bybit")
  legASide       String
  legAEntryPrice Float
  legASize       Float
  legAOrderId    String?
  legBExchange   String    @default("kucoin")
  legBSide       String
  legBEntryPrice Float
  legBSize       Float
  legBOrderId    String?
  size           Float
  entrySpread    Float
  currentSpread  Float?
  unrealizedPnl  Float?
  realizedPnl    Float?
  status         String    @default("OPEN")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  @@index([status, mode])
}

model Order {
  id             String   @id @default(uuid())
  positionId     String?
  exchange       String
  symbol         String
  side           String
  orderType      String
  size           Float
  price          Float?
  reduceOnly     Boolean  @default(false)
  clientOrderId  String?
  requestPayload String
  responseRaw    String?
  status         String
  latencyMs      Int?
  errorMessage   String?
  createdAt      DateTime @default(now())
  mode           String   @default("paper")
  @@index([positionId])
  @@index([mode])
}

model PaperAccount {
  id        Int      @id @default(autoincrement())
  exchange  String   @unique
  balance   Float    @default(10000)
  currency  String   @default("USDT")
  updatedAt DateTime @default(now())
}