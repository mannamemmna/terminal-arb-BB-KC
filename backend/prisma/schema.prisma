generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Config {
  id   String @id @default("main")
  json String
}

model Signal {
  id          Int      @id @default(autoincrement())
  symbol      String
  message     String
  verdict     String
  spreadPct   Float
  fundingDiff Float
  createdAt   DateTime @default(now())

  @@index([symbol, createdAt])
}

model Trade {
  id          Int       @id @default(autoincrement())
  symbol      String
  sideBybit   String
  sideKucoin  String
  entrySpread Float
  exitSpread  Float?
  pnl         Float?
  status      String    @default("OPEN")
  mode        String    @default("paper")
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  @@index([status, createdAt])
  @@index([mode])
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  bybit     String
  kucoin    String
  uptime    Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Position {
  id             String    @id @default(uuid())
  symbol         String
  mode           String
  legAExchange   String    @default("bybit")
  legASide       String
  legAEntryPrice Float
  legASize       Float
  legAOrderId    String?
  legBExchange   String    @default("kucoin")
  legBSide       String
  legBEntryPrice Float
  legBSize       Float
  legBOrderId    String?
  size           Float
  entrySpread    Float
  currentSpread  Float?
  unrealizedPnl  Float?
  realizedPnl    Float?
  status         String    @default("OPEN")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  opportunityType String?  @default("mean_reversion")

  @@index([status, mode])
}

model Order {
  id             String   @id @default(uuid())
  positionId     String?
  exchange       String
  symbol         String
  side           String
  orderType      String
  size           Float
  price          Float?
  reduceOnly     Boolean  @default(false)
  clientOrderId  String?
  requestPayload String
  responseRaw    String?
  status         String
  latencyMs      Int?
  errorMessage   String?
  createdAt      DateTime @default(now())
  mode           String   @default("paper")

  @@index([positionId])
  @@index([mode])
}

model PaperAccount {
  id        Int      @id @default(autoincrement())
  exchange  String   @unique
  balance   Float    @default(10000)
  currency  String   @default("USDT")
  updatedAt DateTime @default(now())
}

model HistoricalCandle {
  id        Int      @id @default(autoincrement())
  exchange  String
  symbol    String
  interval  String
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float

  @@unique([exchange, symbol, interval, timestamp])
  @@index([symbol, interval, timestamp])
}

model HistoricalFunding {
  id          Int      @id @default(autoincrement())
  exchange    String
  symbol      String
  timestamp   DateTime
  fundingRate Float

  @@unique([exchange, symbol, timestamp])
  @@index([symbol, timestamp])
}

model BacktestRun {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  status          String
  paramsJson      String
  resultsJson     String?
  equityCurveJson String?
}

model BacktestTrade {
  id          Int      @id @default(autoincrement())
  runId       String
  symbol      String
  entryAt     DateTime
  exitAt      DateTime
  entrySpread Float
  exitSpread  Float
  spreadPnl   Float
  fundingPnl  Float
  feesPaid    Float
  totalPnl    Float
}

model ApiCredential {
  id            Int      @id @default(autoincrement())
  exchange      String   // 'bybit' | 'kucoin'
  mode          String   // 'testnet' | 'live'
  apiKeyEnc     String   // encrypted
  apiSecretEnc  String   // encrypted
  passphraseEnc String?  // encrypted, KuCoin only
  isValid       Boolean  @default(false)
  lastValidated DateTime?
  updatedAt     DateTime @updatedAt

  @@unique([exchange, mode])
}
