# Spread Arb Terminal — Backend Configuration
# Copy this file to .env and fill in your values

PORT=3001
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="file:./dev.db"

# ---- Bybit ----
# Public endpoints (no API key needed for market data)
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_REST_URL=https://api.bybit.com

# DEMO (Testnet) — get API keys from https://testnet.bybit.com
BYBIT_DEMO_REST_URL=https://api-testnet.bybit.com
BYBIT_DEMO_WS_URL=wss://stream-testnet.bybit.com/v5/public/linear
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

# LIVE (Mainnet)
BYBIT_LIVE_REST_URL=https://api.bybit.com
BYBIT_LIVE_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_LIVE_API_KEY=
BYBIT_LIVE_API_SECRET=

# ---- KuCoin ----
# Public endpoints
KUCOIN_REST_URL=https://api-futures.kucoin.com

# DEMO (Sandbox) — get API keys from https://sandbox-futures.kucoin.com
KUCOIN_DEMO_REST_URL=https://api-sandbox-futures.kucoin.com
KUCOIN_DEMO_API_KEY=
KUCOIN_DEMO_API_SECRET=
KUCOIN_DEMO_API_PASSPHRASE=

# LIVE (Mainnet)
KUCOIN_LIVE_REST_URL=https://api-futures.kucoin.com
KUCOIN_LIVE_API_KEY=
KUCOIN_LIVE_API_SECRET=
KUCOIN_LIVE_API_PASSPHRASE=

# ---- Settings Password ----
# If set, Settings drawer & protected API endpoints require login.
# Password is hashed with HMAC-SHA256 at runtime.
SETTINGS_PASSWORD=
