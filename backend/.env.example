# Backend Environment Variables
# Copy to .env and fill in values

# Server
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=file:./dev.db

# Auth
SETTINGS_PASSWORD=your_secure_password_here

# Encryption (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Bybit Live
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bybit Testnet
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# KuCoin Live
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# KuCoin Testnet
KUCOIN_TESTNET_API_KEY=
KUCOIN_TESTNET_API_SECRET=
KUCOIN_TESTNET_PASSPHRASE=

# Optional: Reset paper data on startup
RESET_PAPER_DATA_ON_STARTUP=true